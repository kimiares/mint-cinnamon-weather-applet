{
    "layout": {
        "type": "layout",
        "pages": ["main"],
        "main": {
            "type": "page",
            "title": "Настройки погоды",
            "sections": ["location", "display"]
        },
        "location": {
            "type": "section",
            "title": "Местоположение",
            "keys": ["city-name", "latitude", "longitude", "timezone"]
        },
        "display": {
            "type": "section",
            "title": "Обновление",
            "keys": ["refresh-interval"]
        }
    },

    "city-name": {
        "type": "entry",
        "default": "Shepetivka",
        "description": "Название города"
    },
    "latitude": {
        "type": "spinbutton",
        "default": 55.7558,
        "min": -90.0,
        "max": 90.0,
        "step": 0.0001,
        "digits": 4,
        "description": "Широта"
    },
    "longitude": {
        "type": "spinbutton",
        "default": 37.6173,
        "min": -180.0,
        "max": 180.0,
        "step": 0.0001,
        "digits": 4,
        "description": "Долгота"
    },
    "timezone": {
        "type": "entry",
        "default": "auto",
        "description": "Часовой пояс (например Europe/Moscow или auto)"
    },
    "refresh-interval": {
        "type": "spinbutton",
        "default": 600,
        "min": 60,
        "max": 3600,
        "step": 60,
        "units": "сек",
        "description": "Интервал обновления"
    }
}
